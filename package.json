{
  "name": "openclaw-langgraph-bridge",
  "version": "0.12.3",
  "description": "OpenClaw plugin that lets any agent drive LangGraph workflows from inside a conversation thread with proactive event wake-back.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Grace Gettert",
  "repository": {
    "type": "git",
    "url": "https://github.com/ggettert/openclaw-langgraph-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/ggettert/openclaw-langgraph-bridge/issues"
  },
  "homepage": "https://github.com/ggettert/openclaw-langgraph-bridge#readme",
  "keywords": [
    "openclaw",
    "langgraph",
    "plugin",
    "agent-orchestration",
    "workflows"
  ],
  "engines": {
    "node": ">=20"
  },
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "smoke": "node --import tsx scripts/smoke-langgraph.ts",
    "smoke:webhook": "node --import tsx scripts/smoke-webhook.ts",
    "smoke:streaming": "node --import tsx scripts/smoke-streaming.ts"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "openclaw": "latest",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
