{
  "name": "openclaw-langgraph-bridge",
  "version": "0.7.0",
  "description": "OpenClaw plugin bridging Kit-as-orchestrator with LangGraph workflows. Tools: langgraph_dispatch, langgraph_inspect. Webhook routes events back into Kit's session via enqueueSystemEvent + requestHeartbeat. Per-Slack-thread isolation via managedFlows.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "smoke": "node --import tsx scripts/smoke-langgraph.ts",
    "smoke:webhook": "node --import tsx scripts/smoke-webhook.ts",
    "smoke:streaming": "node --import tsx scripts/smoke-streaming.ts"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "openclaw": "latest",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
