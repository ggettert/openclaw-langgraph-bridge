{
  "name": "@ggettert/openclaw-langgraph-bridge",
  "version": "0.14.0",
  "description": "OpenClaw plugin that lets any agent drive LangGraph workflows from inside a conversation thread with proactive event wake-back.",
  "type": "module",
  "license": "MIT",
  "author": "Grace Gettert",
  "repository": {
    "type": "git",
    "url": "https://github.com/ggettert/openclaw-langgraph-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/ggettert/openclaw-langgraph-bridge/issues"
  },
  "homepage": "https://github.com/ggettert/openclaw-langgraph-bridge#readme",
  "keywords": [
    "openclaw",
    "langgraph",
    "plugin",
    "agent-orchestration",
    "workflows"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "test": "npm run lint && vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "skills",
    "docs"
  ],
  "peerDependencies": {
    "openclaw": "^2026.6.9"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "~4.1.9",
    "eslint": "^10.5.0",
    "openclaw": "^2026.6.9",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "~4.1.9"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  }
}
