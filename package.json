{
  "name": "openclaw-langgraph-bridge",
  "version": "0.12.4",
  "description": "OpenClaw plugin that lets any agent drive LangGraph workflows from inside a conversation thread with proactive event wake-back.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Grace Gettert",
  "repository": {
    "type": "git",
    "url": "https://github.com/ggettert/openclaw-langgraph-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/ggettert/openclaw-langgraph-bridge/issues"
  },
  "homepage": "https://github.com/ggettert/openclaw-langgraph-bridge#readme",
  "keywords": [
    "openclaw",
    "langgraph",
    "plugin",
    "agent-orchestration",
    "workflows"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "test": "npm run lint && vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "smoke": "node --import tsx scripts/smoke-langgraph.ts",
    "smoke:webhook": "node --import tsx scripts/smoke-webhook.ts",
    "smoke:streaming": "node --import tsx scripts/smoke-streaming.ts"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "~3.2.6",
    "eslint": "^10.5.0",
    "openclaw": "latest",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "~3.2.6"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  }
}
